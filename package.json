{
  "name": "wanjie-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:game",
    "dev:game": "node ./node_modules/vite/bin/vite.js --configLoader runner --config vite.workspace.mjs --mode game",
    "dev:admin": "node ./node_modules/vite/bin/vite.js --configLoader runner --config vite.workspace.mjs --mode admin",
    "dev:api": "pnpm --dir apps/api dev",
    "build": "pnpm build:shared && pnpm build:game && pnpm build:admin && pnpm build:api",
    "build:shared": "pnpm --dir packages/contracts build && pnpm --dir packages/game-rules build && pnpm --dir packages/ui build",
    "build:game": "node ./node_modules/typescript/bin/tsc -p apps/game-web/tsconfig.json",
    "build:admin": "node ./node_modules/typescript/bin/tsc -p apps/admin-web/tsconfig.json",
    "build:api": "pnpm --dir apps/api build",
    "bundle:game": "node ./node_modules/vite/bin/vite.js build --configLoader runner --config vite.workspace.mjs --mode game",
    "bundle:admin": "node ./node_modules/vite/bin/vite.js build --configLoader runner --config vite.workspace.mjs --mode admin",
    "lint": "pnpm lint:game && pnpm lint:admin && pnpm lint:api",
    "lint:game": "eslint apps/game-web/src --ext .ts,.tsx",
    "lint:admin": "eslint apps/admin-web/src --ext .ts,.tsx",
    "lint:api": "pnpm --dir apps/api lint",
    "preview": "node ./node_modules/vite/bin/vite.js preview --configLoader runner --config vite.workspace.mjs --mode game",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.18",
    "framer-motion": "^12.29.2",
    "immer": "^11.1.3",
    "localforage": "^1.10.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
